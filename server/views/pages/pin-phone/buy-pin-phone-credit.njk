{% extends "../../partials/layout.njk" %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/input/macro.njk" import govukInput %}

{% set pageTitle = "Buy PIN phone credit" %}
{% set ownAmountHtml %}
  {{ govukInput({
    id: "custom-amount",
    name: "customAmount",
    classes: "govuk-input--width-5",
    label: {
      text: "Enter amount in pounds"
    },
    prefix: {
      text: "£"
    },
    value: customAmountValue,
    spellcheck: false
  }) }}
{% endset %}
{% block pageTitle %}
  {{ pageTitle }} - GOV.UK
{% endblock %}

{% block content %}
  <h1 class="govuk-heading-l">{{ pageTitle }}</h1>

  {{ govukTable({
    classes: "govuk-!-width-two-thirds",
    firstCellIsHeader: false,
    rows: [
      [
        {
          text: "Current PIN phone credit",
          classes: "govuk-!-width-one-half govuk-!-font-weight-bold"
        },
        {
          text: "£" + pinPhoneCredit
        }
      ],
      [
        {
          text: "Spends balance",
          classes: "govuk-!-font-weight-bold"
        },
        {
          text: "£" + spendsBalance
        }
      ],
      [
        {
          text: "PIN phone credit limit",
          classes: "govuk-!-font-weight-bold"
        },
        {
          text: "£" + pinPhoneCreditLimit
        }
      ]
    ]
  }) }}
  {% from "govuk/components/inset-text/macro.njk" import govukInsetText %}

  {% call govukInsetText() %}
     You can buy upto £{{ creditBuyCapacity }}
  {% endcall %}

  {{ govukRadios({
    idPrefix: "pin_amount",
    name: "amount",
    fieldset: {
      legend: {
        text: "How much PIN phone credit would you like to buy?",
        classes: "govuk-fieldset__legend--m"
      }
    },
    items: [
     { value: "0.50", text: "£0.50", checked: finalAmount == "0.50" },
     { value: "1", text: "£1.00", checked: finalAmount == "1" },
     { value: "3", text: "£3.00", checked: finalAmount == "3" },
     { value: "5", text: "£5.00", checked: finalAmount == "5" },
     {
         value: creditBuyCapacity,
         text: "Max (£" + creditBuyCapacity + ")",
         checked: finalAmount == creditBuyCapacity
     },
     {
        value: "own-amount",
        text: "or add your own amount",
        checked: finalAmount == "own-amount",
        conditional: {
          html: ownAmountHtml
        }
     }
    ]
    }) }}

<div class="govuk-radios">

  <div class="govuk-radios__item">
    <input class="govuk-radios__input" id="amount-1" name="amount" type="radio" value="1">
    <label class="govuk-label govuk-radios__label" for="amount-1">£1</label>
  </div>

  <div class="govuk-radios__item">
    <input class="govuk-radios__input" id="amount-2" name="amount" type="radio" value="2">
    <label class="govuk-label govuk-radios__label" for="amount-2">£2</label>
  </div>

  <div class="govuk-radios__item">
    <input class="govuk-radios__input" id="amount-5" name="amount" type="radio" value="5">
    <label class="govuk-label govuk-radios__label" for="amount-5">£5</label>
  </div>

  <div class="govuk-radios__item">
    <input class="govuk-radios__input" id="amount-10" name="amount" type="radio" value="10">
    <label class="govuk-label govuk-radios__label" for="amount-10">£10</label>
  </div>

  <div class="govuk-body govuk-!-margin-top-4">
    Add your own value
  </div>

 <div style="display: flex; align-items: center; gap: 15px;">
      <!-- Radio Button -->
      <div class="govuk-radios__item" style="float: none; clear: none;">
        <input class="govuk-radios__input" id="example-radio" name="example-group" type="radio" value="yes">
        <label class="govuk-label govuk-radios__label" for="example-radio">
          <div class="govuk-form-group" style="margin-bottom: 0; flex-grow: 1;">
                  <span>£</span>
                              <input
                                class="govuk-input govuk-input--width-5"
                                id="pin_amount_custom"
                                name="amount_custom"
                                type="text">
                </div>
        </label>
      </div>
    </div>
</div>

{% endblock %}
