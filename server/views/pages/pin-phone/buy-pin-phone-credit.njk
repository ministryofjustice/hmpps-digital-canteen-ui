{% extends "../../partials/layout.njk" %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}

{% set pageTitle = "Buy PIN phone credit" %}

{% set otherAmount %}
  {{ govukInput({
    id: "customAmount",
    name: "customAmount",
    classes: "govuk-input--width-5",
    prefix: {
      text: "£"
    }
  }) }}
{% endset %}

{% block pageTitle %}
  {{ pageTitle }} - GOV.UK
{% endblock %}

{% block content %}
 {{ govukBackLink({
    text: "Back",
    href: "/pin-phone"})
 }}

<form method="post" novalidate>
  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
  <h1 class="govuk-heading-l">{{ pageTitle }}</h1>

  {{ govukTable({
    classes: "govuk-!-width-two-thirds",
    firstCellIsHeader: false,
    rows: [
      [
        {
          text: "Current PIN phone credit",
          classes: "govuk-!-width-one-half govuk-!-font-weight-bold"
        },
        {
          text: "£" + pinPhoneCredit
        }
      ],
      [
        {
          text: "Spends balance",
          classes: "govuk-!-font-weight-bold"
        },
        {
          text: "£" + spendsBalance
        }
      ],
      [
        {
          text: "PIN phone credit limit",
          classes: "govuk-!-font-weight-bold"
        },
        {
          text: "£" + pinPhoneCreditLimit
        }
      ]
    ]
  }) }}

  {% call govukInsetText() %}
     You can buy upto £{{ creditBuyCapacity }}
  {% endcall %}

{{ govukRadios({
  classes: "pin-credit-radios",
  name: "amount",
  fieldset: {
    legend: {
      text: "How much PIN phone credit would you like to buy?",
      classes: "govuk-fieldset__legend--m"
    }
  },
  items: [
    {
      value: "0.50",
      text: "£0.50"
    },
    {
      value: "1",
      text: "£1.00"
    },
    {
      value: "3",
      text: "£3.00"
    },
    {
      value: "5",
      text: "£5.00"
    },
    {
     value: creditBuyCapacity,
     text: "Max (£" +  creditBuyCapacity  +")"
    },
    {
      divider: "Or add your own amount"
    },
    {
      value: "other",
      html: otherAmount
    }
  ]
}) }}
{{ govukButton({
    text: "Continue",
    type: "submit"
  }) }}
</form>

{% endblock %}
