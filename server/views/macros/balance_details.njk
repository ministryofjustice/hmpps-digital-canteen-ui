
{% set handsetIcon %}
<svg width="50" height="50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
</svg>
{% endset %}
{% macro balanceDetails( currentBalance, spendBalance, newBalance) %}
<div class="govuk-grid-row">
  <!-- Current credit -->
  <div class="govuk-grid-column-one-quarter">
    <div class="credit-card">
      <div class="credit-card__icon-wrapper">
        {{ handsetIcon | safe }}
      </div>
      <div class="credit-card__content">
        <div class="credit-card__label">Current credit balance</div>
        <div id="currentBalanceDisplay" class="credit-card__value">
          £{{ currentBalance | fixed }}
        </div>
      </div>
    </div>
  </div>

  <!-- Spend balance -->
  <div class="govuk-grid-column-one-quarter">
    <div class="credit-card">
      <div class="credit-card__content">
        <div class="credit-card__label">Spends balance</div>
        <div id="spendBalanceDisplay" class="credit-card__value" data-starting-spend="{{ spendBalance }}">
          £{{ spendBalance | fixed }}
        </div>
      </div>
    </div>
  </div>

  <!-- New balance -->
  <div class="govuk-grid-column-one-quarter">
    <div class="credit-card credit-card--highlight">
      <div class="credit-card__icon-wrapper">
        {{ handsetIcon | safe }}
      </div>
      <div class="credit-card__content">
        <div class="credit-card__label">New credit balance</div>
        <div id="newBalanceDisplay" class="credit-card__value" data-starting-balance="{{ currentBalance }}">
          £{{ newBalance | fixed }}
        </div>
      </div>
    </div>
  </div>

</div>

{% endmacro %}
